# ════════════════════════════════════════════════════════
# AbuseRadar — environment template
# Copy this to .env (local dev) or .env.production (server).
# Never commit the real .env files (they're gitignored).
# ════════════════════════════════════════════════════════

# ─── Environment ───
# "development" enables hot-reload and exposed ports.
# "production" disables reload, restart-always, used with docker-compose.prod.yml.
APP_ENV=development

# ─── Project ───
PROJECT_NAME=AbuseRadar
PROJECT_DOMAIN=abuseradar.org
LOG_LEVEL=INFO
# In dev this is your local browser URL; in prod it's https://abuseradar.org
PUBLIC_BASE_URL=http://localhost:8765
REPORT_BASE_URL=http://localhost:8765/console/report.html

# ─── Database (Postgres) ───
POSTGRES_USER=spamwatch
POSTGRES_PASSWORD=change_me_to_a_strong_random_string
POSTGRES_DB=spamwatch
DATABASE_URL=postgresql+asyncpg://spamwatch:change_me_to_a_strong_random_string@db:5432/spamwatch

# ─── Cache (Redis) ───
REDIS_URL=redis://redis:6379/0

# ─── External APIs ───
# Get one at https://aistudio.google.com/apikey  (gemini-2.5-flash + image)
GEMINI_API_KEY=your_gemini_api_key_here

# Get one at https://resend.com  (after verifying abuseradar.org domain)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=alerts@abuseradar.org
EMAIL_REPLY_TO=alerts@abuseradar.org

# ─── Port bindings (host) ───
# In production set PORT_BIND=127.0.0.1 so nginx reverse-proxies these.
# In dev leave empty (or 0.0.0.0) to access from your LAN.
PORT_BIND=
PORT_API=7777
PORT_DASHBOARD=7778
PORT_OPENCLAW=18789
PORT_DB=5432
PORT_REDIS=6380
PORT_WEB=8765

# ─── Resource scaling ───
CRAWLER_MEMORY_LIMIT=4G
OPENCLAW_MEMORY_LIMIT=2G
