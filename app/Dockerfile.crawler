FROM python:3.12-slim-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev curl wget gnupg2 \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 \
    libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxrandr2 \
    libgbm1 libpango-1.0-0 libcairo2 libasound2 libatspi2.0-0 \
    libxfixes3 libx11-xcb1 libxcb1 libxext6 libx11-6 \
    fonts-liberation fonts-noto-color-emoji \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-crawler.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-crawler.txt
RUN playwright install chromium

# Public Suffix List'i build sırasında indir
RUN python -c "import tldextract; tldextract.TLDExtract().update(fetch_now=True)" || true

COPY . .

CMD ["python", "-m", "crawler.worker"]
